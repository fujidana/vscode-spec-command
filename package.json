{
	"publisher": "fujidana",
	"name": "spec-command",
	"displayName": "spec command",
	"description": "spec command file support for VS Code",
	"version": "2.0.1-alpha.1",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Linters"
	],
	"icon": "resources/icon.png",
	"keywords": [
		"X-ray diffraction",
		"synchrotron",
		"instrument control",
		"data acquisition"
	],
	"license": "SEE LICENSE IN LICENSE.txt",
	"bugs": {
		"url": "https://github.com/fujidana/vscode-spec-command/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fujidana/vscode-spec-command.git"
	},
	"homepage": "https://github.com/fujidana/vscode-spec-command#readme",
	"activationEvents": [
		"onFileSystem:spec-command"
	],
	"main": "./dist/node/extension.js",
	"browser": "./dist/web/extension.js",
	"l10n": "./l10n",
	"contributes": {
		"languages": [
			{
				"id": "spec-command",
				"aliases": [
					"spec command",
					"spec macro"
				],
				"extensions": [
					".mac"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "spec-command",
				"scopeName": "source.spec-command",
				"path": "./syntaxes/spec-command.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "spec-command",
				"path": "./syntaxes/spec-command.snippets.json"
			}
		],
		"commands": [
			{
				"command": "spec-command.showDictionaryPreview",
				"title": "%command.spec-command.showDictionaryPreview.title%",
				"category": "spec command",
				"icon": "$(references)"
			},
			{
				"command": "spec-command.showWorkspaceSymbolsJson",
				"title": "%command.spec-command.showWorkspaceSymbols.title%",
				"category": "spec command",
				"icon": "$(json)"
			},
			{
				"command": "spec-command.showDictionarySource",
				"title": "%command.spec-command.showDictionarySource.title%",
				"category": "spec command",
				"icon": "$(repo-pull)"
			},
			{
				"command": "spec-command.registerDictionary",
				"title": "%command.spec-command.registerDictionary.title%",
				"enablement": "editorLangId == json",
				"category": "spec command",
				"icon": "$(repo-push)"
			},
			{
				"command": "spec-command.deleteDictionary",
				"title": "%command.spec-command.deleteDictionary.title%",
				"category": "spec command",
				"icon": "$(trash)"
			},
			{
				"command": "spec-command.inspectSyntaxTree",
				"title": "%command.spec-command.inspectSyntaxTree.title%",
				"category": "spec command",
				"icon": "$(json)"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "spec-command.showDictionaryPreview"
				},
				{
					"command": "spec-command.showWorkspaceSymbolsJson",
					"when": "workspaceFolderCount > 0"
				},
				{
					"command": "spec-command.showDictionarySource"
				},
				{
					"command": "spec-command.registerDictionary",
					"when": "editorLangId == json"
				},
				{
					"command": "spec-command.deleteDictionary"
				},
				{
					"command": "spec-command.inspectSyntaxTree",
					"when": "editorLangId == spec-command"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": [
					"scdict.json",
					"*.scdict.json"
				],
				"url": "./schema/scdict.schema.json"
			}
		],
		"configuration": {
			"title": "spec command",
			"properties": {
				"spec-command.showSymbolsInPreview": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "%configuration.spec-command.showSymbolsInPreview.description%",
					"markdownDeprecationMessage": "**Deprecated**: Please use `#spec-command.dictionaryPreview#` instead."
				},
				"spec-command.specVersion": {
					"type": "string",
					"default": "6.13.4",
					"markdownDescription": "%configuration.spec-command.specVersion.description%",
					"pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
					"patternErrorMessage": "%configuration.spec-command.specVersion.patternErrorMessage%"
				},
				"spec-command.dictionaryPreview": {
					"type": "string",
					"enum": [
						"markdown",
						"preview",
						"markdown+preview"
					],
					"default": "preview",
					"markdownDescription": "%configuration.spec-command.dictionaryPreview.description%"
				},
				"spec-command.suggest.suppressMessages": {
					"type": "object",
					"markdownDescription": "%configuration.spec-command.suggest.suppressMessages.description%",
					"default": {
						"completionItem.label.detail": false,
						"completionItem.label.description": false,
						"completionItem.documentation": false,
						"hover.contents": false,
						"signatureHelp.signatures.documentation": false
					},
					"properties": {
						"completionItem.label.detail": {
							"type": "boolean",
							"default": false,
							"description": "%configuration.spec-command.suggest.suppressMessages.completionItem.label.detail.description%"
						},
						"completionItem.label.description": {
							"type": "boolean",
							"default": false,
							"description": "%configuration.spec-command.suggest.suppressMessages.completionItem.label.description.description%"
						},
						"completionItem.documentation": {
							"type": "boolean",
							"default": false,
							"description": "%configuration.spec-command.suggest.suppressMessages.completionItem.documentation.description%"
						},
						"hover.contents": {
							"type": "boolean",
							"default": false,
							"description": "%configuration.spec-command.suggest.suppressMessages.hover.contents.description%"
						},
						"signatureHelp.signatures.documentation": {
							"type": "boolean",
							"default": false,
							"description": "%configuration.spec-command.suggest.suppressMessages.signatureHelp.signatures.documentation.description%"
						}
					},
					"additionalProperties": false
				},
				"spec-command.suggest.codeSnippets": {
					"type": "object",
					"scope": "window",
					"markdownDescription": "%configuration.spec-command.suggest.codeSnippets.description%",
					"default": {},
					"patternProperties": {
						"^[a-zA-Z_][a-zA-Z0-9_\\-]*$": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				"spec-command.suggest.motors": {
					"type": "object",
					"scope": "window",
					"markdownDescription": "%configuration.spec-command.suggest.motors.description%",
					"default": {},
					"patternProperties": {
						"^[a-zA-Z_][a-zA-Z0-9_]{0,6}$": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				"spec-command.suggest.counters": {
					"type": "object",
					"scope": "window",
					"markdownDescription": "%configuration.spec-command.suggest.counters.description%",
					"default": {
						"sec": "count time in second"
					},
					"patternProperties": {
						"^[a-zA-Z_][a-zA-Z0-9_]{0,6}$": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				"spec-command.suggest.symbolFile": {
					"type": "string",
					"default": "",
					"scope": "window",
					"markdownDescription": "%configuration.spec-command.suggest.symbolFile.description%",
					"markdownDeprecationMessage": "**Deprecated**: Not effective now."
				},
				"spec-command.workspace.exclude": {
					"type": "array",
					"default": [],
					"scope": "resource",
					"markdownDescription": "%configuration.spec-command.workspace.exclude.description%",
					"items": {
						"type": "string"
					}
				},
				"spec-command.workspace.diagnoseProblems": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%configuration.spec-command.workspace.diagnoseProblems.description%"
				},
				"spec-command.problems.rules": {
					"type": "object",
					"tags": [
						"experimental"
					],
					"scope": "resource",
					"description": "%configuration.spec-command.problems.rules.description%",
					"properties": {
						"no-local-outside-block": {
							"type": "boolean",
							"default": false
						},
						"no-undeclared-variable": {
							"type": "boolean",
							"default": false
						},
						"no-undeclared-macro-argument": {
							"type": "boolean",
							"default": false
						}
					},
					"additionalProperties": false
				},
				"spec-command.terminal.filePathPrefix": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"markdownDescription": "%configuration.spec-command.terminal.filePathPrefix.description%",
					"markdownDeprecationMessage": "**Deprecated**: Not effective now."
				}
			}
		}
	},
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": "limited",
			"description": "%capabilities.untrustedWorkspaces.description%",
			"restrictedConfigurations": [
				"spec-command.suggest.symbolFile"
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run js-yaml && pnpm run package",
		"compile": "pnpm run compile:peggy && pnpm run check-types && pnpm run lint && node esbuild.js",
		"compile:peggy": "peggy --dts --cache src/parser.peggy",
		"watch": "npm-run-all -p watch:*",
		"watch:peggy": "peggy -w --dts --cache src/parser.peggy",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run compile:peggy && pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile && pnpm run compile-tests",
		"pretest-web": "pnpm run compile",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test",
		"test-web": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/extensionTests.js",
		"run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
		"js-yaml": "npm-run-all js-yaml:*",
		"js-yaml:snippets": "js-yaml syntaxes/spec-command.snippets.yaml > syntaxes/spec-command.snippets.json",
		"js-yaml:scdict": "js-yaml syntaxes/spec-command.scdict.yaml > syntaxes/spec-command.scdict.json",
		"js-yaml:tmLanguage": "js-yaml syntaxes/spec-command.tmLanguage.yaml > syntaxes/spec-command.tmLanguage.json",
		"l10n-export": "npx @vscode/l10n-dev export -o ./l10n ./src"
	},
	"dependencies": {
		"estraverse": "^5.3.0",
		"semver": "^7.7.4"
	},
	"devDependencies": {
		"@esbuild-plugins/node-globals-polyfill": "^0.2.3",
		"@types/assert": "^1.5.11",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/semver": "^7.7.1",
		"@types/vscode": "^1.110.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/test-web": "^0.0.80",
		"assert": "^2.1.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"glob": "^13.0.6",
		"js-yaml": "^4.1.1",
		"mocha": "^11.7.5",
		"npm-run-all": "^4.1.5",
		"peggy": "^5.1.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@playwright/browser-chromium",
			"esbuild"
		]
	}
}